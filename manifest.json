{
  "manifest_version": 2,
  "name": "Anki Word Adder",
  "version": "1.1.0",
  "description": "Webページから単語を選択してAnkiに追加する拡張機能",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "*://localhost/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "anki-word-adder@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
